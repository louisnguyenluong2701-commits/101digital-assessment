# ---- Root environment for docker-compose ----
# Copy to .env (optional). docker-compose has sensible defaults baked in, so
# this is only needed if you want to override them.

# Database
DB_USERNAME=simpleinvoice
DB_PASSWORD=simpleinvoice
DB_NAME=simpleinvoice

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=3600

# CORS — must match where the frontend is served from
CORS_ORIGIN=http://localhost:8080

# Frontend build-time API base URL (browser -> backend)
VITE_API_BASE_URL=http://localhost:3000

# Seeded admin account
SEED_USER_EMAIL=admin@101digital.io
SEED_USER_PASSWORD='$Abc1234'
SEED_USER_FULLNAME=Admin
