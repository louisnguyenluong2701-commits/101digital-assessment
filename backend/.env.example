# ---- Backend environment configuration ----
# Copy this file to .env and fill in real values.

# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
# When running with Docker Compose, DB_HOST should be the service name: "postgres".
# When running locally without Docker, use "localhost".
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=simpleinvoice
DB_PASSWORD=simpleinvoice
DB_NAME=simpleinvoice
# Auto-create schema from entities. true for this assessment; use migrations in production.
DB_SYNCHRONIZE=true

# JWT
JWT_SECRET=change-me-to-a-long-random-string
# Token lifetime in seconds. Defaults to 3600 (1 hour) if not set.
JWT_EXPIRES_IN=3600

# Default admin account created by the seed script
SEED_USER_EMAIL=admin@101digital.io
SEED_USER_PASSWORD='$Abc1234'
SEED_USER_FULLNAME=Admin

# CORS: comma-separated list of allowed origins for the frontend
CORS_ORIGIN=http://localhost:5173
